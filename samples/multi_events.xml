<?xml version="1.0" encoding="utf-8"?>
<!--
  Three-event chain showing a lateral-movement pattern:
    1. 4648 — jsmith uses explicit credentials (runas) to authenticate as corp-admin
    2. 4688 — runas.exe spawns an elevated cmd.exe under corp-admin's token
