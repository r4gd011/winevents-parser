    <EventData>
      <!-- Subject: corp-admin — the token used to create this process -->
      <Data Name="SubjectUserSid">S-1-5-21-3623811015-3361044348-30300820-1115</Data>
      <Data Name="SubjectUserName">corp-admin</Data>
